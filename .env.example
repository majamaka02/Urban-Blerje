# Flask Configuration
SECRET_KEY=your-super-secret-key-change-this-in-production
DEBUG=False
FLASK_ENV=production
PORT=5000

# Database
DATABASE_URL=sqlite:///stoku.db

# Security
SESSION_COOKIE_SECURE=False
SESSION_COOKIE_SAMESITE=Lax

# Backup Settings
BACKUP_DIR=./backups
BACKUP_ENABLED=True
BACKUP_INTERVAL_HOURS=24
